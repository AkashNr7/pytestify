{
  "info": {
    "_postman_id": "8f8ef56b-4ca0-41ab-8ea2-2cb0c6cb3ce1",
    "name": "Marketplace API Suite",
    "description": "Sample API Collection for the Postman to Pytest Migrator, covering sign-in, listing items, and establishing a secure database resource order with assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - User Authentication",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"test_buyer\",\n  \"password\": \"secure_password_123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "auth",
            "login"
          ]
        },
        "description": "Authenticates a buyer account and retrieves a JWT authorization bearer token."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"JWT access token is returned\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.accessToken).to.not.be.undefined;",
              "    pm.expect(jsonData.expiresIn).to.be.a('number');",
              "    pm.environment.set(\"buyerAccessToken\", jsonData.accessToken);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Products - Get Catalog List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{buyerAccessToken}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/products?limit=10&in_stock=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "products"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "in_stock",
              "value": "true"
            }
          ]
        },
        "description": "Fetches active catalog items filtered by availability rules."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"HTTP Response is 200 Successful\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Verify array contains products\", function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body.items).to.be.an('array');",
              "    pm.expect(body.items.length).to.be.above(0);",
              "    ",
              "    // Preserve catalog details",
              "    var targetItem = body.items[0];",
              "    pm.environment.set(\"selectedProductId\", targetItem.id);",
              "    pm.environment.set(\"selectedProductPrice\", targetItem.price);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Orders - Place Simple Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{buyerAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"{{selectedProductId}}\",\n  \"quantity\": 1,\n  \"priceExpected\": \"{{selectedProductPrice}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "orders"
          ]
        },
        "description": "Places an order using variables derived from the products catalog response."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Order Created Successfully\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Check response body for ID and confirmation status\", function () {",
              "    var res = pm.response.json();",
              "    pm.expect(res.orderId).to.be.a('string');",
              "    pm.expect(res.status).to.eql(\"PENDING\");",
              "    pm.expect(res.amount).to.be.at.least(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
